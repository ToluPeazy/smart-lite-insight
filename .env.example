# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Application ──
DB_PATH=data/processed/energy.db

# ── LLM Agent (Ollama) ──
# Ollama must be running: https://ollama.ai
# Pull model first: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── InfluxDB (future / optional — not used in current release) ──
INFLUX_URL=http://db:8086
INFLUX_ORG=local
INFLUX_BUCKET=energy
INFLUX_TOKEN=change-me

# ── MQTT (future / optional — not used in current release) ──
MQTT_HOST=mqtt
MQTT_PORT=1883
COLLECTOR_LOG_LEVEL=INFO

# ── Dashboard InfluxDB (future / optional) ──
DASHBOARD_INFLUX_URL=http://db:8086
DASHBOARD_INFLUX_ORG=local
DASHBOARD_INFLUX_BUCKET=energy
DASHBOARD_INFLUX_TOKEN=change-me
